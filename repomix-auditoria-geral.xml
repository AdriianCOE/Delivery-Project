    icon: FiZap,
  }
}

function getToneClass(tone, variant = 'soft') {
  const map = {
    green: {
      soft: 'bg-green-50 text-green-700',
      icon: 'bg-green-50 text-green-700',
      dot: 'bg-green-500',
    },
    blue: {
