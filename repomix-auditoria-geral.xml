            <FiCalendar size={22} />
          </div>
          <div>
            <p className="text-sm font-black text-[#111827] dark:text-zinc-100">Sem agendamentos</p>
            <p className="mt-1 text-xs text-[#6b7280] dark:text-zinc-400">Nenhuma encomenda agendada no período.</p>
          </div>
        </div>
