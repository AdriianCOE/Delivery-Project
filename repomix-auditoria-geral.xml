          </div>
        ))}
      </div>
      <p className="mt-3 flex items-center gap-1.5 text-[11px] font-semibold text-[#9ca3af]">
        <FiInfo size={11} />
        Para alterar plano ou assinatura, acesse a área de suporte.
      </p>
    </SectionCard>
  )
}


function ThemeCard() {
