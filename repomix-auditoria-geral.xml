                            ? 'border-[#f97316] bg-orange-50/20 text-[#f97316] dark:bg-orange-500/10'
                            : 'border-gray-100 bg-gray-50 text-[#6b7280] hover:bg-gray-100 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-800'
