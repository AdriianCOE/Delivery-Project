    },
    orange: {
      soft: 'bg-orange-50 text-[#f97316]',
      icon: 'bg-orange-50 text-[#f97316]',
      dot: 'bg-[#f97316]',
    },
  }

  return map[tone]?.[variant] || map.orange[variant]
}

function Toast({ toast, onClose }) {
