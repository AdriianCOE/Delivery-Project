        observation,
        itemObservation: observation,
      })

      setSelectedCartItem((current) => {
        if (!current || getItemKey(current) !== itemKey) return current

        return {
          ...current,
          observation,
          itemObservation: observation,
        }
      })
    },
    [updateCartItem]
