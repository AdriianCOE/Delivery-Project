const BRAZILIAN_MOBILE_PHONE_NATIONAL_DIGITS = 11
const BRAZILIAN_MOBILE_PHONE_FORMATTED_MAX_LENGTH = 15
const PHONE_SEND_SESSION_KEY = '@PratoBy:onboardingPhoneSendState'

