  assert.equal(mapMercadoPagoPaymentStatus({ status: 'approved' }), 'paid')
  assert.equal(mapMercadoPagoPaymentStatus({ status: 'in_process' }), 'pending_payment')
  assert.equal(mapMercadoPagoPaymentStatus({ status: 'rejected' }), 'failed')
