function uniqueArray(values) {
  return [...new Set(values.filter(Boolean))]
}

function normalizeStatus(status) {
  const currentStatus = String(status || 'pendente').toLowerCase().trim()

  const statusMap = {
    novo: 'pendente',
    new: 'pendente',
    recebido: 'pendente',
    recebidos: 'pendente',
    aguardando: 'pendente',
    aguardando_confirmacao: 'pendente',
