      <div className="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <p className="text-sm font-bold text-[#9ca3af]">
          {categories.length} categoria{categories.length !== 1 ? 's' : ''} · use ↑↓ para reordenar
