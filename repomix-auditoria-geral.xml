          setStoreData({
            ...data,
            id: snapshot.id,
            isOpen: data.isOpen ?? true,
          })
        } else {
          setStoreData(null)
        }
        setStoreLoading(false)
      },
      (err) => {
        console.error('Erro ao escutar dados da loja no Topbar:', err)
        setStoreError('Não foi possível carregar o status atual da loja.')
        setStoreLoading(false)
      }
    )

    return () => unsubscribe()
  }, [currentStoreId])

