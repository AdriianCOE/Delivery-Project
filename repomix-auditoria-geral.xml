            className={`flex h-10 w-10 items-center justify-center rounded-2xl transition ${
              star <= value
                ? 'bg-amber-50 text-amber-500'
                : 'bg-gray-50 text-gray-300'
            }`}
            aria-label={`${star} estrela${star > 1 ? 's' : ''}`}
          >
            <FiStar
              size={22}
              className={star <= value ? 'fill-amber-500' : ''}
            />
          </button>
        ))}
