                sound.enabled
                  ? t('bg-orange-500 text-white hover:bg-orange-400', 'bg-orange-500 text-white hover:bg-orange-600')
                  : t('text-zinc-400 hover:bg-zinc-800 hover:text-zinc-100', 'text-gray-500 hover:bg-gray-50 hover:text-gray-900')
              )}
