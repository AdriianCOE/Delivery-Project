                </div>
              )}

              {tables.length > 0 && (
                <div className="mt-5 rounded-xl bg-[#f9fafb] px-4 py-3 dark:bg-zinc-800">
                  <p className="text-xs font-bold text-[#6b7280] dark:text-zinc-400">
                    🔒 Cada mesa usa um token seguro único (ex:{' '}
