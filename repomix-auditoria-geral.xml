const CUSTOMER_KEY = '@PratoBy:customer'
const LEGACY_CUSTOMER_KEY = '@DeliveryApp:customer'
const TRACKING_TOKENS_KEY = '@PratoBy:trackingTokens'

const STATUS_META = {
  pendente: {
    label: 'Aguardando',
    description: 'A loja recebeu seu pedido.',
    icon: FiClock,
