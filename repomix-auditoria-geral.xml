      dot: 'bg-amber-500',
    },
    red: {
      soft: 'bg-red-50 text-red-700',
      icon: 'bg-red-50 text-red-700',
      dot: 'bg-red-500',
    },
    gray: {
      soft: 'bg-gray-100 text-gray-700',
