      if (!data.valid) {
        setAppliedCoupon(null)
        setCouponError(getCouponValidationMessage(data))
        return
      }

      setAppliedCoupon({
        id: data.coupon?.code || code,
        ...(data.coupon || {}),
        code: data.coupon?.code || code,
        discountCents: data.discountCents,
        eligibleSubtotalCents: data.eligibleSubtotalCents,
