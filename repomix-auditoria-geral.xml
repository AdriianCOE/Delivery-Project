                />
              ) : (
                <div className={cn('grid gap-4', readyGrid)}>
                  {visibleReady.map(order => (
                    <ReadyCard
                      key={order.id}
                      order={order}
                      isNew={newIds.has(order.id)}
                      t={t}
                      isDark={isDark}
