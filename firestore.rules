rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAnonymousAuth() {
      return signedIn()
        && request.auth.token.get('firebase', {}).get('sign_in_provider', '') == 'anonymous';
    }

    function signedInNonAnonymous() {
      return signedIn() && !isAnonymousAuth();
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function storePath(storeId) {
      return /databases/$(database)/documents/stores/$(storeId);
    }

    function publicStorePath(storeId) {
      return /databases/$(database)/documents/publicStores/$(storeId);
    }

    function legalConfigPath() {
      return /databases/$(database)/documents/config/legal;
    }

    function validLatestLegalVersions(data) {
      return exists(legalConfigPath())
        && get(legalConfigPath()).data.get('termsVersion', '') is string
        && get(legalConfigPath()).data.get('privacyVersion', '') is string
        && data.termsVersion == get(legalConfigPath()).data.get('termsVersion', '')
        && data.privacyVersion == get(legalConfigPath()).data.get('privacyVersion', '');
    }

    function hasProfile() {
      return signedInNonAnonymous() && exists(userPath(request.auth.uid));
    }

    function me() {
      return get(userPath(request.auth.uid)).data;
    }

function profileStoreIds() {
  return hasProfile()
    && me().keys().hasAny(['storeIds'])
    && me().storeIds is list
      ? me().storeIds
      : [];
}

function profileStoreKeys() {
  return hasProfile()
    && me().keys().hasAny(['storeKeys'])
    && me().storeKeys is list
      ? me().storeKeys
      : [];
}

function myStoreKeys() {
  return hasProfile()
    ? [
        me().get('storeId', ''),
        me().get('storeSlug', '')
      ] + profileStoreIds() + profileStoreKeys()
    : [];
}

function orderStoreKeys(data) {
  return data.keys().hasAny(['storeKeys'])
    && data.storeKeys is list
      ? data.storeKeys
      : [];
}

    function isAdmin() {
      // Reads users/{uid} directly — safe outside the users match block.
      // When called from users/{userId} allow get, this branch is only
      // reached when request.auth.uid != userId (admin reading someone
      // else's doc), so there is no circular read.
      return signedInNonAnonymous()
        && exists(userPath(request.auth.uid))
        && get(userPath(request.auth.uid)).data.get('role', '') in ['admin', 'developer', 'dev'];
    }

    function isPublicStoreData(data) {
      return data.get('isActive', true) != false
        && data.get('isBlocked', false) != true
        && data.get('isBillingBlocked', false) != true
        && data.get('isDeleted', false) != true
        && !(data.get('subscriptionStatus', '') in [
          'blocked',
          'canceled',
          'cancelled',
          'checkout_pending',
          'pending_checkout',
          'billing_pending',
          'billing_pending_payment_method'
        ])
        && (
          data.get('subscriptionStatus', '') == ''
          || data.get('subscriptionStatus', '') in ['trialing', 'active', 'past_due']
        );
    }

    function planRank(plan) {
      return plan == 'premium' ? 3 : plan == 'professional' ? 2 : plan == 'essential' ? 1 : 0;
    }

    function featureRequiredRank(feature) {
      return feature in ['advancedReports', 'customBranding', 'removePratoByBranding', 'automationRules', 'prioritySupport']
        ? 3
        : feature in ['pickupDisplay', 'tableQrCode', 'dineInOrdering', 'scheduling', 'coupons', 'deliveryZonesAdvanced', 'multiUser']
          ? 2
          : 1;
    }

    function storeEffectivePlan(data) {
      return data.get('isBillingBlocked', false) == true
        || data.get('isBlocked', false) == true
        || data.get('isDeleted', false) == true
        || data.keys().hasAny(['deletedAt'])
        || data.get('subscriptionStatus', '') in ['blocked', 'canceled', 'cancelled', 'checkout_pending', 'pending_checkout', 'billing_pending', 'billing_pending_payment_method', 'past_due']
          ? ''
          : data.get('subscriptionStatus', '') == 'trialing'
            ? 'premium'
            : data.get('effectivePlan', data.get('billingPlan', data.get('selectedPlan', data.get('plan', 'essential'))));
    }

    function storeHasPlanFeature(storeId, feature) {
      return exists(storePath(storeId))
        && planRank(storeEffectivePlan(get(storePath(storeId)).data)) >= featureRequiredRank(feature);
    }

    function storeProductImagesLimit(storeId) {
      return exists(storePath(storeId))
        && storeEffectivePlan(get(storePath(storeId)).data) == 'premium'
          ? 5
          : exists(storePath(storeId)) && storeEffectivePlan(get(storePath(storeId)).data) == 'professional'
            ? 3
            : 1;
    }

    function productUsesScheduling(data) {
      return data.get('orderMode', '') == 'scheduled_only'
        || data.get('availabilityMode', '') == 'scheduled_only'
        || data.get('scheduling', {}).get('mode', 'store_default') in ['scheduled_only', 'asap_and_scheduled']
        || data.get('scheduling', {}).get('orderMode', '') == 'scheduled_only'
        || data.get('scheduling', {}).get('prepaymentPolicy', '') == 'pix_required';
    }

    function productImagesWithinPlan(data) {
      let limit = storeProductImagesLimit(data.get('storeId', ''));
      return (!(data.get('images', []) is list) || data.get('images', []).size() <= limit)
        && (!(data.get('imageUrls', []) is list) || data.get('imageUrls', []).size() <= limit)
        && (!(data.get('gallery', []) is list) || data.get('gallery', []).size() <= limit);
    }

    function productSchedulingUnchanged(beforeData, afterData) {
      return afterData.get('orderMode', '') == beforeData.get('orderMode', '')
        && afterData.get('availabilityMode', '') == beforeData.get('availabilityMode', '')
        && afterData.get('scheduling', {}) == beforeData.get('scheduling', {});
    }

    function productImagesUnchanged(beforeData, afterData) {
      return afterData.get('images', []) == beforeData.get('images', [])
        && afterData.get('imageUrls', []) == beforeData.get('imageUrls', [])
        && afterData.get('gallery', []) == beforeData.get('gallery', []);
    }

    function productCreateAllowedByPlan(data) {
      return (!productUsesScheduling(data) || storeHasPlanFeature(data.get('storeId', ''), 'scheduling'))
        && productImagesWithinPlan(data);
    }

    function productUpdateAllowedByPlan(beforeData, afterData) {
      return (
          !productUsesScheduling(afterData)
          || storeHasPlanFeature(afterData.get('storeId', ''), 'scheduling')
          || productSchedulingUnchanged(beforeData, afterData)
        )
        && (
          productImagesWithinPlan(afterData)
          || productImagesUnchanged(beforeData, afterData)
        );
    }

    function couponWriteAllowedByPlan(data) {
      return storeHasPlanFeature(data.get('storeId', ''), 'coupons');
    }

    function couponDeactivateOrArchiveOnly() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['active', 'isDeleted', 'deletedAt', 'updatedAt'])
        && changed.hasAny(['active', 'isDeleted', 'deletedAt'])
        && request.resource.data.get('active', false) == false
        && (!changed.hasAny(['isDeleted']) || request.resource.data.get('isDeleted', false) == true)
        && (!changed.hasAny(['deletedAt']) || request.resource.data.deletedAt is timestamp)
        && (!changed.hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp);
    }

    function isStoreOwnerData(data) {
      return signedInNonAnonymous() && (
        data.get('ownerId', '') == request.auth.uid ||
        data.get('ownerUid', '') == request.auth.uid ||
        request.auth.uid in data.get('allowedUserIds', []) ||
        request.auth.uid in data.get('merchantUids', []) ||
        data.get('storeId', '') in myStoreKeys() ||
        data.get('storeSlug', '') in myStoreKeys() ||
        data.get('slug', '') in myStoreKeys()
      );
    }

    function canManageStoreData(data) {
      return isAdmin() || isStoreOwnerData(data);
    }

    function canManageStoreId(storeId) {
      return isAdmin() || (
        storeId is string &&
        storeId != '' &&
        (
          storeId in myStoreKeys() ||
          (exists(storePath(storeId)) && isStoreOwnerData(get(storePath(storeId)).data))
        )
      );
    }

    function validNotificationTokenCreate(storeId, tokenId) {
      return signedInNonAnonymous()
        && canManageStoreId(storeId)
        && tokenId is string
        && tokenId.size() == 64
        && request.resource.data.keys().hasOnly([
          'uid',
          'storeId',
          'token',
          'enabled',
          'platform',
          'userAgent',
          'createdAt',
          'updatedAt',
          'lastSeenAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.storeId == storeId
        && request.resource.data.token is string
        && request.resource.data.token.size() > 20
        && request.resource.data.token.size() <= 4096
        && request.resource.data.enabled is bool
        && request.resource.data.platform is string
        && request.resource.data.platform.size() <= 120
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 600
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastSeenAt is timestamp;
    }

    function validNotificationTokenUpdate(storeId, tokenId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();

      return signedInNonAnonymous()
        && canManageStoreId(storeId)
        && tokenId is string
        && tokenId.size() == 64
        && resource.data.uid == request.auth.uid
        && resource.data.storeId == storeId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.token == resource.data.token
        && request.resource.data.createdAt == resource.data.createdAt
        && changed.hasOnly([
          'enabled',
          'platform',
          'userAgent',
          'updatedAt',
          'lastSeenAt'
        ])
        && (!changed.hasAny(['enabled']) || request.resource.data.enabled is bool)
        && (!changed.hasAny(['platform']) || (
          request.resource.data.platform is string
          && request.resource.data.platform.size() <= 120
        ))
        && (!changed.hasAny(['userAgent']) || (
          request.resource.data.userAgent is string
          && request.resource.data.userAgent.size() <= 600
        ))
        && (!changed.hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp)
        && (!changed.hasAny(['lastSeenAt']) || request.resource.data.lastSeenAt is timestamp);
    }

    function publicStoreExists(storeId) {
      return storeId is string
        && exists(publicStorePath(storeId))
        && isPublicStoreData(get(publicStorePath(storeId)).data)
        && exists(storePath(storeId))
        && isPublicStoreData(get(storePath(storeId)).data);
    }

    function storeFieldUnchanged(field) {
      return request.resource.data.get(field, null) == resource.data.get(field, null);
    }

    function protectedStoreFieldsUnchanged() {
      return storeFieldUnchanged('owner')
        && storeFieldUnchanged('ownerId')
        && storeFieldUnchanged('ownerUid')
        && storeFieldUnchanged('ownerEmail')
        && storeFieldUnchanged('allowedUserIds')
        && storeFieldUnchanged('merchantUids')
        && storeFieldUnchanged('role')
        && storeFieldUnchanged('roles')
        && storeFieldUnchanged('team')
        && storeFieldUnchanged('members')
        && storeFieldUnchanged('staff')
        && storeFieldUnchanged('createdAt')
        && storeFieldUnchanged('createdBy')
        && storeFieldUnchanged('isOpen')
        && storeFieldUnchanged('isBlocked')
        && storeFieldUnchanged('isBillingBlocked')
        && storeFieldUnchanged('isDeleted')
        && storeFieldUnchanged('deletedAt')
        && storeFieldUnchanged('subscriptionStatus')
        && storeFieldUnchanged('subscription')
        && storeFieldUnchanged('planId')
        && storeFieldUnchanged('planName')
        && storeFieldUnchanged('slug')
        && storeFieldUnchanged('storeSlug')
        && storeFieldUnchanged('storeId')
        && storeFieldUnchanged('storeKeys')
        && storeFieldUnchanged('plan')
        && storeFieldUnchanged('selectedPlan')
        && storeFieldUnchanged('billingPlan')
        && storeFieldUnchanged('effectivePlan')
        && storeFieldUnchanged('trialEntitlementsPlan')
        && storeFieldUnchanged('billingCycle')
        && storeFieldUnchanged('trialStartedAt')
        && storeFieldUnchanged('trialEndsAt')
        && storeFieldUnchanged('trialEndedAt')
        && storeFieldUnchanged('firstChargeAt')
        && storeFieldUnchanged('nextChargeAt')
        && storeFieldUnchanged('onboardingStatus')
        && storeFieldUnchanged('billingProvider')
        && storeFieldUnchanged('payments')
        && storeFieldUnchanged('billingMethodConfigured')
        && storeFieldUnchanged('asaasCustomerId')
        && storeFieldUnchanged('asaasSubscriptionId')
        && storeFieldUnchanged('asaasSubscriptionStatus')
        && storeFieldUnchanged('providerCustomerId')
        && storeFieldUnchanged('providerSubscriptionId')
        && storeFieldUnchanged('providerCheckoutId')
        && storeFieldUnchanged('subscriptionId')
        && storeFieldUnchanged('currentPeriodEnd')
        && storeFieldUnchanged('lastAsaasSyncAt')
        && storeFieldUnchanged('lastPaymentId')
        && storeFieldUnchanged('lastPaymentStatus')
        && storeFieldUnchanged('asaasCheckoutId')
        && storeFieldUnchanged('asaasCheckoutUrl')
        && storeFieldUnchanged('asaasCheckoutExpiresAt')
        && storeFieldUnchanged('checkoutUrl')
        && storeFieldUnchanged('billingCheckout')
        && storeFieldUnchanged('billingCheckoutStatus')
        && storeFieldUnchanged('cancelAtTrialEnd')
        && storeFieldUnchanged('subscriptionCancellationStatus')
        && storeFieldUnchanged('subscriptionCancellationReason')
        && storeFieldUnchanged('cancelScheduledAtPeriodEnd')
        && storeFieldUnchanged('cancelScheduledAtTrialEnd')
        && storeFieldUnchanged('subscriptionCancelRequestedAt')
        && storeFieldUnchanged('subscriptionCancelRequestedBy')
        && storeFieldUnchanged('subscriptionReactivatedAt')
        && storeFieldUnchanged('subscriptionReactivatedBy')
        && storeFieldUnchanged('trialTransitionProcessedAt')
        && storeFieldUnchanged('amountCents')
        && storeFieldUnchanged('billingType');
    }

function ownsOrderData(data) {
  return canManageStoreId(data.get('storeId', ''))
    || canManageStoreId(data.get('storeSlug', ''))
    || canManageStoreId(data.get('storeDocId', ''))
    || orderStoreKeys(data).hasAny(myStoreKeys());
}

function ownsStoreScopedData(data) {
  return canManageStoreId(data.get('storeId', ''))
    || canManageStoreId(data.get('storeSlug', ''))
    || canManageStoreId(data.get('storeDocId', ''))
    || (
      data.keys().hasAny(['storeKeys'])
      && data.storeKeys is list
      && data.storeKeys.hasAny(myStoreKeys())
    );
}

function validPublicOrderCreate(orderId) {
  return request.resource.data.get('trackingToken', '') is string
    && request.resource.data.get('trackingToken', '') == orderId
    && request.resource.data.get('storeId', '') is string
    && publicStoreExists(request.resource.data.storeId)
    && request.resource.data.get('source', '') == 'storefront'
    && request.resource.data.get('status', '') == 'pendente'
    && !(request.resource.data.get('paymentStatus', '') in ['paid', 'pago', 'confirmed'])
    && request.resource.data.get('totalCents', 0) is int
    && request.resource.data.totalCents > 0
    && request.resource.data.totalCents < 100000000
    && request.resource.data.get('customerPhone', '') is string
    && request.resource.data.get('items', []) is list
    && request.resource.data.items.size() > 0;
}

    function validReviewCreate(reviewId) {
      let orderId = request.resource.data.get('orderId', '');
      let orderPath = /databases/$(database)/documents/orders/$(orderId);
      let orderData = get(orderPath).data;

      return orderId is string
        && orderId != ''
        && reviewId == orderId
        && exists(orderPath)
        && request.resource.data.keys().hasOnly([
          'storeId',
          'storeSlug',
          'storeDocId',
          'storeKeys',
          'orderId',
          'trackingToken',
          'customerName',
          'customerPhone',
          'rating',
          'foodRating',
          'deliveryRating',
          'serviceRating',
          'wouldOrderAgain',
          'tags',
          'comment',
          'isPublic',
          'resolved',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.get('storeId', '') == orderData.get('storeId', '')
        && request.resource.data.get('trackingToken', '') == orderData.get('trackingToken', '')
        && request.resource.data.get('customerPhone', '') == orderData.get('customerPhone', '')
        && orderData.get('status', '') in ['entregue', 'delivered', 'concluido', 'concluído', 'finalizado', 'finished']
        && request.resource.data.get('rating', 0) is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.get('isPublic', false) == false
        && request.resource.data.get('resolved', false) == false;
    }

    function validMerchantReviewUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();

      return canManageStoreId(resource.data.get('storeId', ''))
        && request.resource.data.get('storeId', '') == resource.data.get('storeId', '')
        && changed.hasOnly([
          'merchantReply',
          'merchantReplyAt',
          'merchantReplyBy',
          'isPublic',
          'resolved',
          'resolvedAt',
          'moderationStatus',
          'updatedAt'
        ])
        && (!changed.hasAny(['merchantReply']) || request.resource.data.get('merchantReply', '') is string)
        && (!changed.hasAny(['merchantReplyAt']) || request.resource.data.get('merchantReplyAt', null) is timestamp)
        && (!changed.hasAny(['merchantReplyBy']) || request.resource.data.get('merchantReplyBy', '') == request.auth.uid)
        && (!changed.hasAny(['isPublic']) || request.resource.data.get('isPublic', false) is bool)
        && (!changed.hasAny(['resolved']) || request.resource.data.get('resolved', false) is bool)
        && (
          !changed.hasAny(['resolvedAt'])
          || (
            request.resource.data.get('resolved', false) == true
            && request.resource.data.get('resolvedAt', null) is timestamp
          )
          || (
            request.resource.data.get('resolved', false) == false
            && request.resource.data.get('resolvedAt', null) == null
          )
        )
        && (!changed.hasAny(['moderationStatus']) || request.resource.data.get('moderationStatus', '') in ['pending', 'public', 'hidden', 'resolved'])
        && (!changed.hasAny(['updatedAt']) || request.resource.data.get('updatedAt', null) is timestamp);
    }

    function validSignupUserCreate(data) {
  return data.keys().hasOnly([
    'uid',
    'role',
    'email',
    'displayName',
    'phone',
    'phoneVerified',
    'plan',
    'billingCycle',
    'subscriptionStatus',
    'onboardingStatus',
    'storeId',
    'storeIds',
    'storeKeys',
    'signup',
    'termsAccepted',
    'termsAcceptedAt',
    'termsVersion',
    'privacyVersion',
    'marketingOptIn',
    'marketingOptInAt',
    'marketingOptInSource',
    'createdAt',
    'updatedAt'
  ])
  && data.signup is map
  && data.signup.keys().hasOnly([
    'storeName',
    'segment',
    'city',
    'source',
    'authProvider'
  ])
  && data.uid == request.auth.uid
  && data.role == 'merchant'
  && data.subscriptionStatus == 'pending_checkout'
  && data.onboardingStatus == 'phone_pending'
  && data.phoneVerified == false
  && data.storeId == null
  && data.storeIds == []
  && data.storeKeys == []
  && data.keys().hasAll([
    'termsAccepted',
    'termsAcceptedAt',
    'termsVersion',
    'privacyVersion',
    'marketingOptIn'
  ])
  && data.termsAccepted == true
  && data.termsAcceptedAt is timestamp
  && validLatestLegalVersions(data)
  && data.marketingOptIn is bool
  && (
    (data.marketingOptIn == false
      && !data.keys().hasAny(['marketingOptInAt', 'marketingOptInSource']))
    ||
    (data.marketingOptIn == true
      && data.keys().hasAll(['marketingOptInAt', 'marketingOptInSource'])
      && data.marketingOptInAt is timestamp
      && data.marketingOptInSource == 'signup')
  )
  && data.plan in ['essential', 'professional', 'premium']
  && data.billingCycle in ['monthly', 'annual']
  && data.signup.source == 'signup_page'
  && data.signup.authProvider in ['google', 'password'];
}

  match /users/{userId} {
  allow get: if (signedInNonAnonymous() && request.auth.uid == userId) || isAdmin();
  allow list: if isAdmin();

  allow create: if signedInNonAnonymous()
    && request.auth.uid == userId
    && !exists(userPath(userId))
    && validSignupUserCreate(request.resource.data);

  allow update, delete: if isAdmin();
}

    match /config/{configId} {
      allow get: if configId == 'legal';
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    match /stores/{storeId} {
      allow get, list: if canManageStoreData(resource.data);
      allow create: if isAdmin();
      allow update: if (isAdmin() && storeFieldUnchanged('isOpen'))
        || (isStoreOwnerData(resource.data) && protectedStoreFieldsUnchanged());
      allow delete: if isAdmin();

      match /notificationTokens/{tokenId} {
        allow get: if isAdmin()
          || (
            signedInNonAnonymous()
            && canManageStoreId(storeId)
            && tokenId is string
            && tokenId.size() == 64
          );

        allow list: if false;

        allow create: if validNotificationTokenCreate(storeId, tokenId);

        allow update: if validNotificationTokenUpdate(storeId, tokenId);

        allow delete: if isAdmin()
          || (
            signedInNonAnonymous()
            && canManageStoreId(storeId)
            && resource.data.uid == request.auth.uid
            && resource.data.storeId == storeId
          );
      }

      // QR Code por mesa — escrita somente via callable (createStoreTable, updateStoreTable, archiveStoreTable)
      match /tables/{tableId} {
        allow get, list: if canManageStoreId(storeId);
        allow create, update, delete: if false;
      }
    }

    match /publicStores/{storeId} {
      allow get, list: if isPublicStoreData(resource.data)
        && exists(storePath(storeId))
        && isPublicStoreData(get(storePath(storeId)).data);
      allow create, update, delete: if false;

      match /products/{productId} {
        allow get, list: if publicStoreExists(storeId);
        allow create, update, delete: if false;
      }

      match /categories/{categoryId} {
        allow get, list: if publicStoreExists(storeId);
        allow create, update, delete: if false;
      }
    }

    match /categories/{categoryId} {
      allow read: if canManageStoreId(resource.data.get('storeId', ''));
      allow create: if canManageStoreId(request.resource.data.get('storeId', ''));
      allow update: if canManageStoreId(resource.data.get('storeId', ''))
        && request.resource.data.get('storeId', '') == resource.data.get('storeId', '');
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if canManageStoreId(resource.data.get('storeId', ''));
      allow create: if canManageStoreId(request.resource.data.get('storeId', ''))
        && productCreateAllowedByPlan(request.resource.data);
      allow update: if canManageStoreId(resource.data.get('storeId', ''))
        && request.resource.data.get('storeId', '') == resource.data.get('storeId', '')
        && productUpdateAllowedByPlan(resource.data, request.resource.data);
      allow delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if canManageStoreId(resource.data.get('storeId', ''));
      allow create: if canManageStoreId(request.resource.data.get('storeId', ''))
        && couponWriteAllowedByPlan(request.resource.data);
      allow update: if canManageStoreId(resource.data.get('storeId', ''))
        && request.resource.data.get('storeId', '') == resource.data.get('storeId', '')
        && (
          couponWriteAllowedByPlan(request.resource.data)
          || couponDeactivateOrArchiveOnly()
        );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isAdmin()
        || ownsOrderData(resource.data)
        || resource.data.get('trackingToken', '') == orderId;

      allow list: if isAdmin() || ownsOrderData(resource.data);

      allow create: if false;

      allow update: if isAdmin();

      allow delete: if isAdmin();

      match /customerNotificationTokens/{tokenId} {
        allow read, write: if false;
      }
    }

    // Operational capacity reservations for scheduled orders.
    // Cloud Functions using the Admin SDK bypass these rules; clients must not
    // read or write this collection directly.
    match /scheduledOrderSlots/{slotId} {
      allow read, write: if false;
    }

    // Mercado Pago OAuth state and per-store provider credentials are backend-only.
    // Cloud Functions/Admin SDK manage these documents; clients must never read
    // access tokens, refresh tokens, nonces or connection internals directly.
    match /mercadoPagoOAuthStates/{stateId} {
      allow read, write: if false;
    }

    match /storePaymentProviders/{storeId}/{document=**} {
      allow read, write: if false;
    }

    match /auditLogs/{logId} {
      allow get, list: if isAdmin() || ownsStoreScopedData(resource.data);
      allow create, update, delete: if false;
    }

    match /reviews/{reviewId} {
      allow get, list: if canManageStoreId(resource.data.get('storeId', ''))
        || (resource.data.get('isPublic', false) == true && publicStoreExists(resource.data.get('storeId', '')));
      allow create: if validReviewCreate(reviewId);
      allow update: if isAdmin() || validMerchantReviewUpdate();
      allow delete: if isAdmin();
    }

    match /phoneVerifications/{docId} {
      allow read, write: if false;
    }

    match /phoneClaims/{docId} {
      allow read, write: if false;
    }

    match /storeSlugClaims/{docId} {
      allow read, write: if false;
    }

    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    match /billingLocks/{docId} {
      allow read, write: if false;
    }

    match /billingCheckouts/{docId} {
      allow read, write: if false;
    }

    match /billingRecovery/{docId} {
      allow read, write: if false;
    }

    match /subscriptionChangeRequests/{docId} {
      allow get, list: if isAdmin() || ownsStoreScopedData(resource.data);
      allow create, update, delete: if false;
    }

    match /subscriptionCancellationRequests/{docId} {
      allow get, list: if isAdmin() || ownsStoreScopedData(resource.data);
      allow create, update, delete: if false;
    }

    match /subscriptionDueDateRequests/{docId} {
      allow get, list: if isAdmin() || ownsStoreScopedData(resource.data);
      allow create, update, delete: if false;
    }

    match /providerEvents/{docId} {
      allow read, write: if false;
    }

    match /notificationLogs/{logId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
