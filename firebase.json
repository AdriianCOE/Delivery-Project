{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate, no-transform"
          }
        ]
      },
      {
        "regex": "^/[^.]*$",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate, no-transform"
          }
        ]
      },
      {
        "source": "/robots.txt",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/sitemap.xml",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/.well-known/security.txt",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          },
          {
            "key": "Content-Type",
            "value": "text/plain; charset=utf-8"
          }
        ]
      },
      {
        "source": "/humans.txt",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          },
          {
            "key": "Content-Type",
            "value": "text/plain; charset=utf-8"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/icons/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      },
      {
        "source": "/og/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      },
      {
        "source": "/favicon.*",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      },
      {
        "source": "/site.webmanifest",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      },
      {
        "source": "/third-party-loader.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      },
      {
        "source": "/firebase-messaging-sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains; preload"
          },
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          },
          {
            "key": "Cross-Origin-Resource-Policy",
            "value": "same-site"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=()"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'sha256-LZczC6WlpMMN4ykEyl+bN+Ze/F2xU4YoCyB55nVRqeE=' https://www.google.com https://www.gstatic.com https://apis.google.com https://www.googletagmanager.com https://googletagmanager.com https://client.crisp.chat; script-src-elem 'self' 'sha256-LZczC6WlpMMN4ykEyl+bN+Ze/F2xU4YoCyB55nVRqeE=' https://www.google.com https://www.gstatic.com https://apis.google.com https://www.googletagmanager.com https://googletagmanager.com https://client.crisp.chat; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://client.crisp.chat; img-src 'self' data: blob: https://www.google.com https://www.gstatic.com https://res.cloudinary.com https://*.googleusercontent.com https://*.gstatic.com https://client.crisp.chat https://image.crisp.chat https://storage.crisp.chat; font-src 'self' data: https://fonts.gstatic.com https://client.crisp.chat; connect-src 'self' https://www.google.com https://www.gstatic.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://firestore.googleapis.com https://firebaseinstallations.googleapis.com https://fcmregistrations.googleapis.com https://fcm.googleapis.com https://api.cloudinary.com https://viacep.com.br https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://*.cloudfunctions.net https://*.run.app https://www.google-analytics.com https://region1.google-analytics.com https://analytics.google.com https://client.crisp.chat https://client.relay.crisp.chat wss://client.relay.crisp.chat; frame-src 'self' https://www.google.com https://recaptcha.google.com https://accounts.google.com https://client.crisp.chat; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
          }
        ]
      }
    ],
    "redirects": [
      {
        "regex": "^/(login|cadastro|onboarding|dashboard|admin|planos|sobre|contato|exemplos|privacidade|privacy|termos|terms)/+$",
        "destination": "/:1",
        "type": 301
      },
      {
        "source": "/privacy",
        "destination": "/privacidade",
        "type": 301
      },
      {
        "source": "/terms",
        "destination": "/termos",
        "type": 301
      },
      {
        "regex": "^/planos(?:\\]|%5[Dd])/?$",
        "destination": "/planos",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },

      {
        "source": "/login",
        "destination": "/index.html"
      },
      {
        "source": "/cadastro",
        "destination": "/index.html"
      },
      {
        "source": "/onboarding",
        "destination": "/index.html"
      },
      {
        "source": "/auth/action",
        "destination": "/index.html"
      },

      {
        "source": "/dashboard",
        "destination": "/index.html"
      },
      {
        "source": "/dashboard/**",
        "destination": "/index.html"
      },
      {
        "source": "/admin",
        "destination": "/index.html"
      },
      {
        "source": "/admin/**",
        "destination": "/index.html"
      },

      {
        "source": "/store/**",
        "destination": "/index.html"
      },
      {
        "source": "/pedido/**",
        "destination": "/index.html"
      },
      {
        "source": "/tracking/**",
        "destination": "/index.html"
      },
      {
        "source": "/order/**",
        "destination": "/index.html"
      },

      {
        "source": "/orders",
        "destination": "/index.html"
      },
      {
        "source": "/menu",
        "destination": "/index.html"
      },
      {
        "source": "/statistics",
        "destination": "/index.html"
      },
      {
        "source": "/Statistics",
        "destination": "/index.html"
      },
      {
        "source": "/settings",
        "destination": "/index.html"
      },
      {
        "source": "/reviews",
        "destination": "/index.html"
      },
      {
        "source": "/Reviews",
        "destination": "/index.html"
      },
      {
        "source": "/qrcodes",
        "destination": "/index.html"
      },
      {
        "source": "/users",
        "destination": "/index.html"
      },
      {
        "source": "/out-screen",
        "destination": "/index.html"
      },
      {
        "source": "/motoboy",
        "destination": "/index.html"
      },

      {
        "source": "/planos",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/sobre",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/contato",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/exemplos",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/privacidade",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/termos",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/cardapio-digital",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/delivery-sem-comissao",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/sistema-para-confeitaria",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/sistema-para-lanchonete",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/sistema-para-pizzaria",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/cardapio-digital-para-restaurante",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/Cardapio-Digital",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },

      {
        "regex": "^/([A-Za-z0-9][A-Za-z0-9-]{1,120})/?$",
        "function": {
          "functionId": "storefrontSeoPreview",
          "region": "southamerica-east1"
        }
      },

      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}

