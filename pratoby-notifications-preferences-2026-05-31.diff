+      if (aboveElements.length > 0) {
+        const lastAbove = aboveElements[aboveElements.length - 1]
+        lastAbove.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
+      }
+    }
+  }, [containerRef])
+
+  return { hiddenAbove, hiddenBelow, scrollToNextHidden }
