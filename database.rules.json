{
    "rules": {
      ".read": false,
      ".write": false,
  
      "presence": {
        "$storeId": {
          ".read": false,
  
          "$sessionId": {
            ".write": "auth != null && $sessionId == auth.uid && (newData.val() == null || newData.hasChildren(['online', 'connectedAt']))",
  
            "online": {
              ".validate": "newData.isBoolean() && newData.val() == true"
            },
  
            "connectedAt": {
              ".validate": "newData.isNumber()"
            },
  
            "$other": {
              ".validate": false
            }
          }
        }
      },

      "presenceCounts": {
        "$storeId": {
          "activeCount": {
            ".read": true,
            ".write": false,
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },

          "$other": {
            ".read": false,
            ".write": false
          }
        }
      }
    }
  }
