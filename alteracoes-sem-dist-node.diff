+    if (!acceptsWindowAndInterval(
+      productWindows,
+      scheduledInput.dateKey,
+      scheduledInput.minuteOfDay,
+      slotIntervalMinutes,
+      productInterval
+    )) {
+      failWith(fail, 'failed-precondition', 'Horário indisponível. Escolha outro horário.')
+    }
+  }
