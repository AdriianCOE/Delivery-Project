+    () => decide({
+      products: [
+        product('asap', { mode: 'asap_only' }),
+        product('custom', { mode: 'scheduled_only' }),
+      ],
+    }),
+    /Finalize em pedidos separados/
+  )
+})
+
+test('uses the highest product lead time', () => {
+  assert.throws(
+    () => decide({
+      products: [product('custom', { mode: 'scheduled_only', minLeadMinutes: 2880 })],
