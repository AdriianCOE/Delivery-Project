+    return {
+      orderTiming: 'asap',
+      scheduledFor: null,
+      scheduledWindowStart: null,
+      scheduledWindowEnd: null,
+      scheduledDateKey: null,
+      scheduledTimeLabel: null,
+      scheduledSlotKey: null,
+      schedulingSnapshot: null,
