+  const hasScheduledOnly = normalizedProducts.some((product) => product.mode === 'scheduled_only')
+
+  if (hasAsapOnly && hasScheduledOnly) {
+    failWith(
+      fail,
+      'failed-precondition',
+      'Este carrinho contém itens com regras diferentes. Finalize em pedidos separados.'
+    )
+  }
