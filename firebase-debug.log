[debug] [2026-06-08T08:12:23.438Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/borapedir-f529a/rulesets {"name":"projects/borapedir-f529a/rulesets/74e8a43c-8692-49f0-a742-4f1f30e603d4","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    function signedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function isAnonymousAuth() {\r\n      return signedIn()\r\n        && request.auth.token.get('firebase', {}).get('sign_in_provider', '') == 'anonymous';\r\n    }\r\n\r\n    function signedInNonAnonymous() {\r\n      return signedIn() && !isAnonymousAuth();\r\n    }\r\n\r\n    function userPath(uid) {\r\n      return /databases/$(database)/documents/users/$(uid);\r\n    }\r\n\r\n    function storePath(storeId) {\r\n      return /databases/$(database)/documents/stores/$(storeId);\r\n    }\r\n\r\n    function publicStorePath(storeId) {\r\n      return /databases/$(database)/documents/publicStores/$(storeId);\r\n    }\r\n\r\n    function legalConfigPath() {\r\n      return /databases/$(database)/documents/config/legal;\r\n    }\r\n\r\n    function validLatestLegalVersions(data) {\r\n      return exists(legalConfigPath())\r\n        && get(legalConfigPath()).data.get('termsVersion', '') is string\r\n        && get(legalConfigPath()).data.get('privacyVersion', '') is string\r\n        && data.termsVersion == get(legalConfigPath()).data.get('termsVersion', '')\r\n        && data.privacyVersion == get(legalConfigPath()).data.get('privacyVersion', '');\r\n    }\r\n\r\n    function hasProfile() {\r\n      return signedInNonAnonymous() && exists(userPath(request.auth.uid));\r\n    }\r\n\r\n    function me() {\r\n      return get(userPath(request.auth.uid)).data;\r\n    }\r\n\r\nfunction profileStoreIds() {\r\n  return hasProfile()\r\n    && me().keys().hasAny(['storeIds'])\r\n    && me().storeIds is list\r\n      ? me().storeIds\r\n      : [];\r\n}\r\n\r\nfunction profileStoreKeys() {\r\n  return hasProfile()\r\n    && me().keys().hasAny(['storeKeys'])\r\n    && me().storeKeys is list\r\n      ? me().storeKeys\r\n      : [];\r\n}\r\n\r\nfunction myStoreKeys() {\r\n  return hasProfile()\r\n    ? [\r\n        me().get('storeId', ''),\r\n        me().get('storeSlug', '')\r\n      ] + profileStoreIds() + profileStoreKeys()\r\n    : [];\r\n}\r\n\r\nfunction orderStoreKeys(data) {\r\n  return data.keys().hasAny(['storeKeys'])\r\n    && data.storeKeys is list\r\n      ? data.storeKeys\r\n      : [];\r\n}\r\n\r\n    function isAdmin() {\r\n      // Reads users/{uid} directly — safe outside the users match block.\r\n      // When called from users/{userId} allow get, this branch is only\r\n      // reached when request.auth.uid != userId (admin reading someone\r\n      // else's doc), so there is no circular read.\r\n      return signedInNonAnonymous()\r\n        && exists(userPath(request.auth.uid))\r\n        && get(userPath(request.auth.uid)).data.get('role', '') in ['admin', 'developer', 'dev'];\r\n    }\r\n\r\n    function isPublicStoreData(data) {\r\n      return data.get('isActive', true) != false\r\n        && data.get('isBlocked', false) != true\r\n        && data.get('isBillingBlocked', false) != true\r\n        && data.get('isDeleted', false) != true\r\n        && !(data.get('subscriptionStatus', '') in [\r\n          'blocked',\r\n          'canceled',\r\n          'checkout_pending',\r\n          'pending_checkout',\r\n          'billing_pending',\r\n          'billing_pending_payment_method'\r\n        ])\r\n        && (\r\n          data.get('subscriptionStatus', '') == ''\r\n          || data.get('subscriptionStatus', '') in ['trialing', 'active', 'past_due']\r\n        );\r\n    }\r\n\r\n    function isStoreOwnerData(data) {\r\n      return signedInNonAnonymous() && (\r\n        data.get('ownerId', '') == request.auth.uid ||\r\n        data.get('ownerUid', '') == request.auth.uid ||\r\n        request.auth.uid in data.get('allowedUserIds', []) ||\r\n        request.auth.uid in data.get('merchantUids', []) ||\r\n        data.get('storeId', '') in myStoreKeys() ||\r\n        data.get('storeSlug', '') in myStoreKeys() ||\r\n        data.get('slug', '') in myStoreKeys()\r\n      );\r\n    }\r\n\r\n    function canManageStoreData(data) {\r\n      return isAdmin() || isStoreOwnerData(data);\r\n    }\r\n\r\n    function canManageStoreId(storeId) {\r\n      return isAdmin() || (\r\n        storeId is string &&\r\n        storeId != '' &&\r\n        (\r\n          storeId in myStoreKeys() ||\r\n          (exists(storePath(storeId)) && isStoreOwnerData(get(storePath(storeId)).data))\r\n        )\r\n      );\r\n    }\r\n\r\n    function validNotificationTokenCreate(storeId, tokenId) {\r\n      return signedInNonAnonymous()\r\n        && canManageStoreId(storeId)\r\n        && tokenId is string\r\n        && tokenId.size() == 64\r\n        && request.resource.data.keys().hasOnly([\r\n          'uid',\r\n          'storeId',\r\n          'token',\r\n          'enabled',\r\n          'platform',\r\n          'userAgent',\r\n          'createdAt',\r\n          'updatedAt',\r\n          'lastSeenAt'\r\n        ])\r\n        && request.resource.data.uid == request.auth.uid\r\n        && request.resource.data.storeId == storeId\r\n        && request.resource.data.token is string\r\n        && request.resource.data.token.size() > 20\r\n        && request.resource.data.token.size() <= 4096\r\n        && request.resource.data.enabled is bool\r\n        && request.resource.data.platform is string\r\n        && request.resource.data.platform.size() <= 120\r\n        && request.resource.data.userAgent is string\r\n        && request.resource.data.userAgent.size() <= 600\r\n        && request.resource.data.createdAt is timestamp\r\n        && request.resource.data.updatedAt is timestamp\r\n        && request.resource.data.lastSeenAt is timestamp;\r\n    }\r\n\r\n    function validNotificationTokenUpdate(storeId, tokenId) {\r\n      let changed = request.resource.data.diff(resource.data).affectedKeys();\r\n\r\n      return signedInNonAnonymous()\r\n        && canManageStoreId(storeId)\r\n        && tokenId is string\r\n        && tokenId.size() == 64\r\n        && resource.data.uid == request.auth.uid\r\n        && resource.data.storeId == storeId\r\n        && request.resource.data.uid == resource.data.uid\r\n        && request.resource.data.storeId == resource.data.storeId\r\n        && request.resource.data.token == resource.data.token\r\n        && request.resource.data.createdAt == resource.data.createdAt\r\n        && changed.hasOnly([\r\n          'enabled',\r\n          'platform',\r\n          'userAgent',\r\n          'updatedAt',\r\n          'lastSeenAt'\r\n        ])\r\n        && (!changed.hasAny(['enabled']) || request.resource.data.enabled is bool)\r\n        && (!changed.hasAny(['platform']) || (\r\n          request.resource.data.platform is string\r\n          && request.resource.data.platform.size() <= 120\r\n        ))\r\n        && (!changed.hasAny(['userAgent']) || (\r\n          request.resource.data.userAgent is string\r\n          && request.resource.data.userAgent.size() <= 600\r\n        ))\r\n        && (!changed.hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp)\r\n        && (!changed.hasAny(['lastSeenAt']) || request.resource.data.lastSeenAt is timestamp);\r\n    }\r\n\r\n    function publicStoreExists(storeId) {\r\n      return storeId is string\r\n        && exists(publicStorePath(storeId))\r\n        && isPublicStoreData(get(publicStorePath(storeId)).data)\r\n        && exists(storePath(storeId))\r\n        && isPublicStoreData(get(storePath(storeId)).data);\r\n    }\r\n\r\n    function storeFieldUnchanged(field) {\r\n      return request.resource.data.get(field, null) == resource.data.get(field, null);\r\n    }\r\n\r\n    function protectedStoreFieldsUnchanged() {\r\n      return storeFieldUnchanged('owner')\r\n        && storeFieldUnchanged('ownerId')\r\n        && storeFieldUnchanged('ownerUid')\r\n        && storeFieldUnchanged('ownerEmail')\r\n        && storeFieldUnchanged('allowedUserIds')\r\n        && storeFieldUnchanged('merchantUids')\r\n        && storeFieldUnchanged('role')\r\n        && storeFieldUnchanged('roles')\r\n        && storeFieldUnchanged('team')\r\n        && storeFieldUnchanged('members')\r\n        && storeFieldUnchanged('staff')\r\n        && storeFieldUnchanged('createdAt')\r\n        && storeFieldUnchanged('createdBy')\r\n        && storeFieldUnchanged('isOpen')\r\n        && storeFieldUnchanged('isBlocked')\r\n        && storeFieldUnchanged('isBillingBlocked')\r\n        && storeFieldUnchanged('isDeleted')\r\n        && storeFieldUnchanged('subscriptionStatus')\r\n        && storeFieldUnchanged('subscription')\r\n        && storeFieldUnchanged('planId')\r\n        && storeFieldUnchanged('planName')\r\n        && storeFieldUnchanged('slug')\r\n        && storeFieldUnchanged('storeSlug')\r\n        && storeFieldUnchanged('storeId')\r\n        && storeFieldUnchanged('storeKeys')\r\n        && storeFieldUnchanged('plan')\r\n        && storeFieldUnchanged('billingCycle')\r\n        && storeFieldUnchanged('trialStartedAt')\r\n        && storeFieldUnchanged('trialEndsAt')\r\n        && storeFieldUnchanged('onboardingStatus')\r\n        && storeFieldUnchanged('billingProvider')\r\n        && storeFieldUnchanged('billingMethodConfigured')\r\n        && storeFieldUnchanged('asaasCustomerId')\r\n        && storeFieldUnchanged('asaasSubscriptionId')\r\n        && storeFieldUnchanged('asaasSubscriptionStatus')\r\n        && storeFieldUnchanged('providerCustomerId')\r\n        && storeFieldUnchanged('providerSubscriptionId')\r\n        && storeFieldUnchanged('providerCheckoutId')\r\n        && storeFieldUnchanged('subscriptionId')\r\n        && storeFieldUnchanged('currentPeriodEnd')\r\n        && storeFieldUnchanged('lastAsaasSyncAt')\r\n        && storeFieldUnchanged('lastPaymentId')\r\n        && storeFieldUnchanged('lastPaymentStatus')\r\n        && storeFieldUnchanged('asaasCheckoutId')\r\n        && storeFieldUnchanged('asaasCheckoutUrl')\r\n        && storeFieldUnchanged('asaasCheckoutExpiresAt')\r\n        && storeFieldUnchanged('checkoutUrl')\r\n        && storeFieldUnchanged('billingCheckout')\r\n        && storeFieldUnchanged('billingCheckoutStatus')\r\n        && storeFieldUnchanged('subscriptionCancellationStatus')\r\n        && storeFieldUnchanged('cancelScheduledAtPeriodEnd')\r\n        && storeFieldUnchanged('subscriptionCancelRequestedAt')\r\n        && storeFieldUnchanged('subscriptionCancelRequestedBy')\r\n        && storeFieldUnchanged('amountCents')\r\n        && storeFieldUnchanged('billingType');\r\n    }\r\n\r\nfunction ownsOrderData(data) {\r\n  return canManageStoreId(data.get('storeId', ''))\r\n    || canManageStoreId(data.get('storeSlug', ''))\r\n    || canManageStoreId(data.get('storeDocId', ''))\r\n    || orderStoreKeys(data).hasAny(myStoreKeys());\r\n}\r\n\r\nfunction ownsStoreScopedData(data) {\r\n  return canManageStoreId(data.get('storeId', ''))\r\n    || canManageStoreId(data.get('storeSlug', ''))\r\n    || canManageStoreId(data.get('storeDocId', ''))\r\n    || (\r\n      data.keys().hasAny(['storeKeys'])\r\n      && data.storeKeys is list\r\n      && data.storeKeys.hasAny(myStoreKeys())\r\n    );\r\n}\r\n\r\nfunction validPublicOrderCreate(orderId) {\r\n  return request.resource.data.get('trackingToken', '') is string\r\n    && request.resource.data.get('trackingToken', '') == orderId\r\n    && request.resource.data.get('storeId', '') is string\r\n    && publicStoreExists(request.resource.data.storeId)\r\n    && request.resource.data.get('source', '') == 'storefront'\r\n    && request.resource.data.get('status', '') == 'pendente'\r\n    && !(request.resource.data.get('paymentStatus', '') in ['paid', 'pago', 'confirmed'])\r\n    && request.resource.data.get('totalCents', 0) is int\r\n    && request.resource.data.totalCents > 0\r\n    && request.resource.data.totalCents < 100000000\r\n    && request.resource.data.get('customerPhone', '') is string\r\n    && request.resource.data.get('items', []) is list\r\n    && request.resource.data.items.size() > 0;\r\n}\r\n\r\n    function validReviewCreate(reviewId) {\r\n      let orderId = request.resource.data.get('orderId', '');\r\n      let orderPath = /databases/$(database)/documents/orders/$(orderId);\r\n      let orderData = get(orderPath).data;\r\n\r\n      return orderId is string\r\n        && orderId != ''\r\n        && reviewId == orderId\r\n        && exists(orderPath)\r\n        && request.resource.data.keys().hasOnly([\r\n          'storeId',\r\n          'storeSlug',\r\n          'storeDocId',\r\n          'storeKeys',\r\n          'orderId',\r\n          'trackingToken',\r\n          'customerName',\r\n          'customerPhone',\r\n          'rating',\r\n          'foodRating',\r\n          'deliveryRating',\r\n          'serviceRating',\r\n          'wouldOrderAgain',\r\n          'tags',\r\n          'comment',\r\n          'isPublic',\r\n          'resolved',\r\n          'createdAt',\r\n          'updatedAt'\r\n        ])\r\n        && request.resource.data.get('storeId', '') == orderData.get('storeId', '')\r\n        && request.resource.data.get('trackingToken', '') == orderData.get('trackingToken', '')\r\n        && request.resource.data.get('customerPhone', '') == orderData.get('customerPhone', '')\r\n        && orderData.get('status', '') in ['entregue', 'delivered', 'concluido', 'concluído', 'finalizado', 'finished']\r\n        && request.resource.data.get('rating', 0) is number\r\n        && request.resource.data.rating >= 1\r\n        && request.resource.data.rating <= 5\r\n        && request.resource.data.get('isPublic', false) == false\r\n        && request.resource.data.get('resolved', false) == false;\r\n    }\r\n\r\n    function validMerchantReviewUpdate() {\r\n      let changed = request.resource.data.diff(resource.data).affectedKeys();\r\n\r\n      return canManageStoreId(resource.data.get('storeId', ''))\r\n        && request.resource.data.get('storeId', '') == resource.data.get('storeId', '')\r\n        && changed.hasOnly([\r\n          'merchantReply',\r\n          'merchantReplyAt',\r\n          'merchantReplyBy',\r\n          'isPublic',\r\n          'resolved',\r\n          'resolvedAt',\r\n          'moderationStatus',\r\n          'updatedAt'\r\n        ])\r\n        && (!changed.hasAny(['merchantReply']) || request.resource.data.get('merchantReply', '') is string)\r\n        && (!changed.hasAny(['merchantReplyAt']) || request.resource.data.get('merchantReplyAt', null) is timestamp)\r\n        && (!changed.hasAny(['merchantReplyBy']) || request.resource.data.get('merchantReplyBy', '') == request.auth.uid)\r\n        && (!changed.hasAny(['isPublic']) || request.resource.data.get('isPublic', false) is bool)\r\n        && (!changed.hasAny(['resolved']) || request.resource.data.get('resolved', false) is bool)\r\n        && (\r\n          !changed.hasAny(['resolvedAt'])\r\n          || (\r\n            request.resource.data.get('resolved', false) == true\r\n            && request.resource.data.get('resolvedAt', null) is timestamp\r\n          )\r\n          || (\r\n            request.resource.data.get('resolved', false) == false\r\n            && request.resource.data.get('resolvedAt', null) == null\r\n          )\r\n        )\r\n        && (!changed.hasAny(['moderationStatus']) || request.resource.data.get('moderationStatus', '') in ['pending', 'public', 'hidden', 'resolved'])\r\n        && (!changed.hasAny(['updatedAt']) || request.resource.data.get('updatedAt', null) is timestamp);\r\n    }\r\n\r\n    function validSignupUserCreate(data) {\r\n  return data.keys().hasOnly([\r\n    'uid',\r\n    'role',\r\n    'email',\r\n    'displayName',\r\n    'phone',\r\n    'phoneVerified',\r\n    'plan',\r\n    'billingCycle',